<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dazura Expert v14.1</title>
    <style>
        :root { --primary: #1a2a3a; --accent: #3498db; --success: #27ae60; --bg: #f8fafc; }
        body { font-family: system-ui, -apple-system, sans-serif; background: var(--bg); margin: 0; padding: 15px; color: var(--primary); }
        .container { max-width: 1000px; margin: auto; background: white; padding: 20px; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.1); }
        header { border-bottom: 2px solid #edf2f7; margin-bottom: 20px; padding-bottom: 10px; display: flex; justify-content: space-between; align-items: center; }
        .tabs { display: flex; gap: 8px; margin-bottom: 20px; overflow-x: auto; padding-bottom: 5px; }
        .tab { padding: 10px 16px; cursor: pointer; border-radius: 8px; background: #edf2f7; border: none; font-weight: bold; white-space: nowrap; }
        .tab.active { background: var(--accent); color: white; }
        .section { display: none; }
        .section.active { block: block; display: block; }
        textarea, input { width: 100%; padding: 12px; border: 1px solid #cbd5e0; border-radius: 8px; margin-bottom: 10px; box-sizing: border-box; font-size: 16px; }
        .btn-group { display: flex; gap: 10px; flex-wrap: wrap; }
        button { padding: 12px 20px; border: none; border-radius: 8px; cursor: pointer; font-weight: bold; color: white; background: var(--accent); flex: 1; min-width: 140px; }
        #output { background: #fdfdfd; padding: 15px; border: 1px solid #e2e8f0; border-right: 5px solid var(--accent); border-radius: 8px; white-space: pre-wrap; margin-top: 20px; line-height: 1.6; word-wrap: break-word; }
        .loader { display: none; border: 3px solid #f3f3f3; border-top: 3px solid var(--accent); border-radius: 50%; width: 16px; height: 16px; animation: spin 1s linear infinite; margin-right: 8px; vertical-align: middle; }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
        @media print { .tabs, .admin-only, button, textarea, input, p { display: none !important; } .container { box-shadow: none; border: none; padding: 0; } #output { display: block !important; border: none; } }
    </style>
</head>
<body>

<div class="container">
    <header>
        <h2 style="margin:0;">🛠️ Dazura Expert</h2>
        <span style="font-size: 0.7em; background: #eee; padding: 4px 8px; border-radius: 10px;">v14.1 Stable</span>
    </header>

    <div class="tabs">
        <button class="tab active" onclick="showSection('user-section', this)">ניתוח</button>
        <button class="tab" onclick="showSection('inventory-section', this)">מלאי</button>
        <button class="tab" onclick="showSection('admin-section', this)">הגדרות</button>
    </div>

    <div id="user-section" class="section active">
        <textarea id="inputParts" style="height: 120px;" placeholder="הכנס מק&quot;טים (אחד בכל שורה)..."></textarea>
        <div class="btn-group">
            <button onclick="runAnalysis()">נתח פרויקט <div id="loader" class="loader"></div></button>
            <button style="background:#718096" onclick="window.print()">הדפס PDF</button>
        </div>
        <div id="output">התוצאות יופיעו כאן...</div>
    </div>

    <div id="inventory-section" class="section">
        <h3>📦 מלאי מחסן</h3>
        <textarea id="inventoryData" style="height: 250px;" placeholder="מק&quot;ט, כמות, מיקום..."></textarea>
        <button style="background:var(--success)" onclick="saveData('dazura_inventory', 'inventoryData')">שמור מלאי</button>
    </div>

    <div id="admin-section" class="section">
        <h3>🧠 הגדרות סוכן</h3>
        <textarea id="systemPromptInput" style="height: 250px;"></textarea>
        <input type="password" id="apiKeyInput" placeholder="הדבק API Key כאן">
        <button style="background:var(--success)" onclick="saveAdmin()">שמור הגדרות</button>
    </div>
</div>

<script>
    const MASTER_PROMPT = `אתה מומחה בכיר להנדסת חיווט. נתח את המק"טים שיתקבלו:
1. זיהוי והתאמה: יצרן, AWG, וקוטר בידוד מקסימלי. האם חוט PVC/סיליקון/טפלון יתאימו?
2. מלאי: בדוק אם המק"ט ברשימה שסופקה. ציין מיקום או חלופה מהמלאי.
3. דוח לקוח: טבלה טכנית [attachment_0](attachment), יתרונות ועלות חומר גלם סה"כ.
4. ייצור: שלבי חשיפה, כלי לחיצה והגדרות, וסדר הכנסה.
5. תקלות: רשימת בדיקה (QA).
6. רכש: קישורים ל-Mouser/DigiKey/Farnell.
7. תמחור: הערך עלות ליחידה בכמויות 1, 100, 1000.`;

    window.onload = () => {
        document.getElementById('systemPromptInput').value = localStorage.getItem('dazura_prompt') || MASTER_PROMPT;
        document.getElementById('apiKeyInput').value = localStorage.getItem('dazura_api_key') || "";
        document.getElementById('inventoryData').value = localStorage.getItem('dazura_inventory') || "";
    };

    function showSection(id, el) {
        document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
        document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
        document.getElementById(id).classList.add('active');
        el.classList.add('active');
    }

    function saveData(key, id) {
        localStorage.setItem(key, document.getElementById(id).value);
        alert("נשמר!");
    }

    function saveAdmin() {
        localStorage.setItem('dazura_prompt', document.getElementById('systemPromptInput').value);
        localStorage.setItem('dazura_api_key', document.getElementById('apiKeyInput').value);
        alert("הגדרות Admin נשמרו!");
    }

    async function runAnalysis() {
        const parts = document.getElementById('inputParts').value;
        const prompt = localStorage.getItem('dazura_prompt');
        const inventory = localStorage.getItem('dazura_inventory');
        const apiKey = localStorage.getItem('dazura_api_key');
        
        if (!apiKey) return alert("חסר API Key!");
        if (!parts) return alert("הזן מק\"טים!");

        const loader = document.getElementById('loader');
        const output = document.getElementById('output');
        loader.style.display = "inline-block";
        output.innerText = "מנתח נתונים...";

        try {
            const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${apiKey}`;
            const response = await fetch(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    contents: [{ parts: [{ text: `${prompt}\n\nמלאי פנימי:\n${inventory}\n\nמק"טים לניתוח:\n${parts}` }] }]
                })
            });

            const data = await response.json();
            if (data.candidates && data.candidates[0].content) {
                output.innerText = data.candidates[0].content.parts[0].text;
            } else {
                output.innerText = "שגיאה בתשובה. בדוק את ה-API Key.";
            }
        } catch (e) {
            output.innerText = "שגיאת תקשורת: " + e.message;
        } finally {
            loader.style.display = "none";
        }
    }
</script>
</body>
</html>
